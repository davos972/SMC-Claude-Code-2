# GoldFlow SMC — exemple de configuration frontend
# Copie en `frontend/.env`. URL publique du backend (sans slash final).
# Dev local : http://localhost:8000
# Prod      : https://goldflow-backend.onrender.com
REACT_APP_BACKEND_URL=http://localhost:8000

# Active les endpoints de health-check du dev server (optionnel)
ENABLE_HEALTH_CHECK=false
