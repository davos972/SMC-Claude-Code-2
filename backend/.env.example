# ─────────────────────────────────────────────────────────────
# GoldFlow SMC — exemple de configuration backend
# Copie ce fichier en `backend/.env` et renseigne tes valeurs.
# NE JAMAIS committer le vrai `.env` (il est ignoré par git).
# ─────────────────────────────────────────────────────────────

# MongoDB (obligatoire)
# Ex. local : mongodb://localhost:27017
# Ex. Atlas : mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017

# Nom de la base (optionnel, défaut : goldflow)
DB_NAME=goldflow

# MetaApi (optionnel ici : peut aussi être saisi dans l'app → Réglages)
# Sert de secours au démarrage si la base est vide (ex. nouveau déploiement).
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=

# CORS — origines autorisées, séparées par des virgules.
# Défaut : "*" (toutes). EN PRODUCTION, restreins à l'URL du frontend, ex. :
# CORS_ORIGINS=https://goldflow-frontend.onrender.com
CORS_ORIGINS=*
